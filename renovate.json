{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],

  "regexManagers": [
    {
      "fileMatch": ["Dockerfile*"],
      "matchStrings": [
        "ARG OPENSSL_VERSION=(?<currentValue>.*?)\\s"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "openssl/openssl",
      "extractVersionTemplate": "^openssl-(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "fileMatch": ["Dockerfile*"],
      "matchStrings": [
        "ARG PYTHON_VERSION=(?<currentValue>.*?)\\s"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "python/cpython",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["github-tags"],
      "matchPackageNames": ["openssl/openssl"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDatasources": ["github-tags"],
      "matchPackageNames": ["python/cpython"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "minimumReleaseAge": "3 days"
    }
  ]
}
